# ─── Base de datos ────────────────────────────────────────────────────────────
# Formato: postgresql://USUARIO:PASSWORD@HOST:PUERTO/NOMBRE_BD
DATABASE_URL="postgresql://postgres:password@localhost:5432/4all_db"

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Genera un secreto fuerte con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="6371ec4d6a413e5dd4dac21bb43af0b806af85264f734ab4a473f42ea28afb0b7af5255da80abd9e62ee52147864ae11d10b0aaa8d3c4e73cf78d637ebf55336"
JWT_EXPIRES_IN="7d"

# ─── CORS ─────────────────────────────────────────────────────────────────────
# En producción, especifica el dominio exacto de tu app
CORS_ORIGIN="*"

# ─── Expo (notificaciones push) ───────────────────────────────────────────────
# Opcional: si usas Expo Push Notifications server-side
EXPO_ACCESS_TOKEN="tu_expo_access_token_aqui"

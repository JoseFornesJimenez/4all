// Prisma Schema - 4all App
// Gestión de compañeros de piso

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USUARIO ─────────────────────────────────────────────────────────────────
model User {
  id        String   @id @default(uuid())
  nombre    String
  email     String   @unique
  password  String
  avatar    String?
  pushToken String?  // Token para notificaciones push (Expo)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  pisoId    String?
  piso      Piso?    @relation("MiembrosPiso", fields: [pisoId], references: [id])
  pisosCreados Piso[] @relation("AdminPiso")

  comprasCreadas    ItemCompra[]   @relation("CreadoPor")
  incidenciasCreadas Incidencia[] @relation("CreadaBy")
  incidenciasAsignadas Incidencia[] @relation("AsignadaA")
  gastosCreados     Gasto[]        @relation("PagadoPor")
  turnosAsignados   Turno[]        @relation("TurnoAsignadoA")
  turnosCreados     Turno[]        @relation("TurnoCreadoPor")
  solicitudesCambioEnviadas SolicitudCambioTurno[] @relation("SolicitudCambioSolicitante")
  solicitudesCambioRecibidas SolicitudCambioTurno[] @relation("SolicitudCambioNuevoAsignado")
  deudas            Deuda[]        @relation("Deudor")
  acreedores        Deuda[]        @relation("Acreedor")

  @@map("users")
}

// ─── PISO ─────────────────────────────────────────────────────────────────────
model Piso {
  id          String   @id @default(uuid())
  nombre      String
  direccion   String?
  codigo      String   @unique // Invite code shown to users (6 uppercase hex chars). Share this to let others join the piso.
  adminId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  admin       User     @relation("AdminPiso", fields: [adminId], references: [id])
  miembros    User[]   @relation("MiembrosPiso")
  listaCompra ItemCompra[]
  incidencias Incidencia[]
  gastos      Gasto[]
  turnos      Turno[]

  @@map("pisos")
}

// ─── TURNOS Y CALENDARIO ─────────────────────────────────────────────────────
enum EstadoTurno {
  PENDIENTE
  HECHO
}

model Turno {
  id          String      @id @default(uuid())
  titulo      String
  fecha       DateTime
  estado      EstadoTurno @default(PENDIENTE)
  notas       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relaciones
  pisoId        String
  piso          Piso      @relation(fields: [pisoId], references: [id], onDelete: Cascade)
  asignadoAId   String
  asignadoA     User      @relation("TurnoAsignadoA", fields: [asignadoAId], references: [id])
  creadoPorId   String
  creadoPor     User      @relation("TurnoCreadoPor", fields: [creadoPorId], references: [id])
  solicitudesCambio SolicitudCambioTurno[]

  @@index([pisoId, fecha])
  @@map("turnos")
}

enum EstadoSolicitudCambioTurno {
  PENDIENTE
  ACEPTADA
  RECHAZADA
}

model SolicitudCambioTurno {
  id              String                     @id @default(uuid())
  estado          EstadoSolicitudCambioTurno @default(PENDIENTE)
  mensaje         String?
  createdAt       DateTime                   @default(now())
  respondedAt     DateTime?

  // Relaciones
  turnoId         String
  turno           Turno                      @relation(fields: [turnoId], references: [id], onDelete: Cascade)
  solicitanteId   String
  solicitante     User                       @relation("SolicitudCambioSolicitante", fields: [solicitanteId], references: [id])
  nuevoAsignadoId String
  nuevoAsignado   User                       @relation("SolicitudCambioNuevoAsignado", fields: [nuevoAsignadoId], references: [id])

  @@index([nuevoAsignadoId, estado])
  @@index([turnoId, estado])
  @@map("solicitudes_cambio_turno")
}

// ─── LISTA DE LA COMPRA ───────────────────────────────────────────────────────
model ItemCompra {
  id        String   @id @default(uuid())
  nombre    String
  cantidad  String?  // "2 litros", "1 kg", etc.
  completado Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  pisoId    String
  piso      Piso     @relation(fields: [pisoId], references: [id], onDelete: Cascade)
  creadoPorId String
  creadoPor   User   @relation("CreadoPor", fields: [creadoPorId], references: [id])

  @@map("items_compra")
}

// ─── INCIDENCIAS ──────────────────────────────────────────────────────────────
enum EstadoIncidencia {
  ABIERTA
  EN_PROGRESO
  RESUELTA
}

enum PrioridadIncidencia {
  BAJA
  MEDIA
  ALTA
  URGENTE
}

model Incidencia {
  id          String              @id @default(uuid())
  titulo      String
  descripcion String?
  foto        String?             @db.Text
  estado      EstadoIncidencia    @default(ABIERTA)
  prioridad   PrioridadIncidencia @default(MEDIA)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  resueltaAt  DateTime?

  // Relaciones
  pisoId      String
  piso        Piso   @relation(fields: [pisoId], references: [id], onDelete: Cascade)
  creadaPorId String
  creadaPor   User   @relation("CreadaBy", fields: [creadaPorId], references: [id])
  asignadaAId String?
  asignadaA   User?  @relation("AsignadaA", fields: [asignadaAId], references: [id])

  @@map("incidencias")
}

// ─── GASTOS COMPARTIDOS ───────────────────────────────────────────────────────
model Gasto {
  id          String   @id @default(uuid())
  descripcion String
  monto       Decimal  @db.Decimal(10, 2)
  fecha       DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  pisoId      String
  piso        Piso     @relation(fields: [pisoId], references: [id], onDelete: Cascade)
  pagadoPorId String
  pagadoPor   User     @relation("PagadoPor", fields: [pagadoPorId], references: [id])
  deudas      Deuda[]  // Cuánto debe cada miembro por este gasto

  @@map("gastos")
}

// Deuda individual por gasto (quién debe cuánto a quién).
// Each Gasto generates exactly N-1 Deuda rows, where N is the number of piso
// members at the time of creation. The payer (acreedor) gets one Deuda record
// per other member (deudor) for their proportional share of the expense.
// Example: 4 members, €40 gasto → 3 Deuda rows of €10 each.
model Deuda {
  id        String   @id @default(uuid())
  monto     Decimal  @db.Decimal(10, 2)
  pagada    Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relaciones
  gastoId   String
  gasto     Gasto  @relation(fields: [gastoId], references: [id], onDelete: Cascade)
  deudorId  String
  deudor    User   @relation("Deudor", fields: [deudorId], references: [id])
  acreedorId String
  acreedor   User  @relation("Acreedor", fields: [acreedorId], references: [id])

  @@map("deudas")
}
